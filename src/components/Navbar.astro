---
import ContactIcon from '../assets/mail.svg';
import ProjectIcon from '../assets/briefcase.svg';
import ThemeToggle from './ThemeToggle.astro';
---

<nav
  class='fixed top-0 left-0 right-0 w-full z-50 transition-all bg-background/90 dark:bg-dark-background/90 duration-300 border-b border-gray-light backdrop-blur-md flex items-center justify-between md:p-4 md:px-10'
>
  <div class='flex items-center justify-between w-full'>
    <a href='/' class='font-bold text-lg hover:scale-110 transition-transform'>
      Rafa_BD
    </a>
    <button
      id='menu-btn'
      class='md:hidden p-2 rounded-md hover:bg-primary-light hover:text-village focus:outline-none'
      aria-label='Mostrar menú'
    >
      <svg
        xmlns='http://www.w3.org/2000/svg'
        class='h-6 w-6'
        fill='none'
        viewBox='0 0 24 24'
        stroke='currentColor'
      >
        <path
          stroke-linecap='round'
          stroke-linejoin='round'
          stroke-width='2'
          d='M4 6h16M4 12h16M4 18h16'></path>
      </svg>
    </button>
  </div>
  <ul
    id='menu'
    class='hidden md:flex flex-col md:flex-row items-center gap-4 absolute md:static top-full left-0 w-full md:w-auto bg-background dark:bg-dark-background md:bg-transparent md:dark:bg-transparent p-4 md:p-0'
  >
    <li
      class='hover:bg-primary-light hover:text-village p-1 rounded-md font-bold text-sm transition-colors'
    >
      <a href='#projects' class='flex items-center justify-center gap-1'>
        <ProjectIcon class='size-5 inline' />
        <span>Proyectos </span>
      </a>
    </li>
    <li
      class='hover:bg-primary-light hover:text-village p-1 rounded-md font-bold text-sm transition-colors'
    >
      <a href='#contact' class='flex items-center justify-center gap-1'>
        <ContactIcon class='size-5 inline' />
        <span>Contacto </span>
      </a>
    </li>
    <ThemeToggle />
  </ul>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('menu');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
      }
    });
  </script>
</nav>
